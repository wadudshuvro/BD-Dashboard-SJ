# .claudeignore - Claude Code Context Optimization
# Excludes build artifacts, dependencies, and auto-generated files
# Keeps all source code, migrations, configs, and documentation

# === BUILD & DIST ARTIFACTS ===
dist
dist-ssr
build
*.out
.next
out

# === DEPENDENCIES & LOCK FILES ===
node_modules
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
.pnpm-store

# === IDE & EDITOR CONFIGS ===
.vscode/*
!.vscode/extensions.json
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-workspace
.vim

# === ENVIRONMENT & SECRETS ===
.env
.env.local
.env.*.local
.env.*.private
.env.production.local
.env.test.local

# === TESTING & COVERAGE ===
coverage
.nyc_output
*.lcov
.jest-cache
.bun-cache

# === LOGS & TEMPORARY FILES ===
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.cache
.tmp
*.tmp

# === OS & SYSTEM FILES ===
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# === LARGE MEDIA & BINARY FILES ===
*.mp4
*.avi
*.mov
*.mkv
*.pdf
*.zip
*.tar.gz
*.exe
*.dmg

# === AUTO-GENERATED FILES ===
dist
.next
.out
.eslintcache

# === LOCAL TESTING & TEMP SCRIPTS ===
*.test.html
test-*.ts
test-*.html
verify-*.sql
check-*.sql
deploy-*.bat
deploy-*.sh
start-local-testing.ps1
sync-with-team.*

# === LOVABLE METADATA (auto-generated by Lovable CLI) ===
.lovable

# === Keep these patterns - DO NOT IGNORE ===
# !src/**
# !supabase/**
# !CLAUDE.md
# !README.md
# !.claude/**
# !.git/**
# !.gitignore
# !tsconfig*.json
# !vite.config.ts
# !tailwind.config.ts
# !package.json
# !components.json
# !eslint.config.mjs
# !postcss.config.js
